rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isStaff() {
      return hasRole('staff') || isAdmin();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        (isOwner(userId) && request.resource.data.role == 'member') || 
        isAdmin()
      );
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // PWD Profiles
    match /pwd_profiles/{profileId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Applications (Unified)
    match /applications/{appId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isStaff() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid
      );
      allow delete: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Counters for generating Application IDs
    match /counters/{counterId} {
      // Allowed for all authenticated users since they generate refs
      allow read, write: if isSignedIn();
    }

    // Certifications
    match /certifications/{certId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Audit Logs
    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isStaff();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isStaff();
      allow update: if isOwner(resource.data.userId);
    }
  }
}
